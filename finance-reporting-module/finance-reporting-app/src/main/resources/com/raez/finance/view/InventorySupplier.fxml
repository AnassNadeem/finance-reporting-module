<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>
<?import java.lang.String?>
<?import javafx.collections.FXCollections?>

<!--
  ROOT is ScrollPane — requires:  <?import javafx.scene.control.ScrollPane?>
  This import was MISSING in the original file, causing the LoadException.
-->
<ScrollPane
    fx:id="pageScrollPane"
    fitToWidth="true"
    hbarPolicy="NEVER"
    vbarPolicy="AS_NEEDED"
    style="-fx-background-color: transparent; -fx-background: #F9FAFB;"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.raez.finance.controller.InventorySupplierController">

    <content>
        <VBox spacing="24" style="-fx-background-color: #F9FAFB;">
            <padding><Insets top="28" right="28" bottom="32" left="28" /></padding>

            <!-- ══════════════════════════
                 HEADER
            ══════════════════════════ -->
            <HBox alignment="CENTER_LEFT" spacing="0">
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label text="Inventory &amp; Supplier Performance"
                           style="-fx-font-size: 22px; -fx-font-weight: 700; -fx-text-fill: #111827;" />
                    <Label text="Current stock value, COGS and supplier reliability"
                           style="-fx-font-size: 13px; -fx-text-fill: #6B7280;" />
                </VBox>

                <MenuButton
                    fx:id="exportMenuButton"
                    styleClass="export-menu-button"
                    text="  Export"
                    style="-fx-background-color: #1E2939; -fx-text-fill: white;
                           -fx-font-size: 13px; -fx-font-weight: 600;
                           -fx-padding: 9 18 9 18; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-border-color: transparent;">
                    <graphic>
                        <SVGPath content="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4-4m4 4V4" fill="TRANSPARENT" stroke="white" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="1.5" />
                    </graphic>
                    <items>
                        <MenuItem fx:id="exportCsvItem" text="Export as CSV" onAction="#handleExportCsv">
                            <graphic>
                                <SVGPath content="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" fill="TRANSPARENT" stroke="#10B981" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="2.0" />
                            </graphic>
                        </MenuItem>
                        <MenuItem fx:id="exportPdfItem" text="Export as PDF" onAction="#handleExportPdf">
                            <graphic>
                                <SVGPath content="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" fill="TRANSPARENT" stroke="#EF4444" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="2.0" />
                            </graphic>
                        </MenuItem>
                    </items>
                </MenuButton>
            </HBox>

            <!-- ══════════════════════════
                 KPI CARDS  (2 columns)
            ══════════════════════════ -->
            <GridPane hgap="20" vgap="20">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50" />
                    <ColumnConstraints percentWidth="50" />
                </columnConstraints>
                <rowConstraints><RowConstraints /></rowConstraints>

                <!-- Stock Value card -->
                <VBox GridPane.columnIndex="0"
                      spacing="6"
                      style="-fx-background-color: white;
                             -fx-border-color: #E5E7EB; -fx-border-radius: 10;
                             -fx-background-radius: 10;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
                    <padding><Insets top="22" right="24" bottom="22" left="24" /></padding>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="📦"  style="-fx-font-size: 20px;" />
                        <VBox spacing="2">
                            <Label text="Current Stock Value"
                                   style="-fx-font-size: 12px; -fx-font-weight: 600;
                                          -fx-text-fill: #6B7280; -fx-text-transform: uppercase;" />
                            <Label fx:id="lblStockValue" text="£0.00"
                                   style="-fx-font-size: 26px; -fx-font-weight: 700; -fx-text-fill: #111827;" />
                            <Label text="Total value of products in stock"
                                   style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF;" />
                        </VBox>
                    </HBox>
                </VBox>

                <!-- COGS card -->
                <VBox GridPane.columnIndex="1"
                      spacing="6"
                      style="-fx-background-color: white;
                             -fx-border-color: #E5E7EB; -fx-border-radius: 10;
                             -fx-background-radius: 10;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
                    <padding><Insets top="22" right="24" bottom="22" left="24" /></padding>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="💸" style="-fx-font-size: 20px;" />
                        <VBox spacing="2">
                            <Label text="COGS — Last 3 Months"
                                   style="-fx-font-size: 12px; -fx-font-weight: 600;
                                          -fx-text-fill: #6B7280; -fx-text-transform: uppercase;" />
                            <Label fx:id="lblCogs" text="£0.00"
                                   style="-fx-font-size: 26px; -fx-font-weight: 700; -fx-text-fill: #111827;" />
                            <Label text="Cost of goods sold"
                                   style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF;" />
                        </VBox>
                    </HBox>
                </VBox>
            </GridPane>

            <!-- ══════════════════════════
                 SUPPLIER TABLE CARD
            ══════════════════════════ -->
            <VBox style="-fx-background-color: white;
                         -fx-border-color: #E5E7EB; -fx-border-radius: 10;
                         -fx-background-radius: 10;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">

                <!-- Card header -->
                <HBox alignment="CENTER_LEFT" spacing="0"
                      style="-fx-border-color: transparent transparent #E5E7EB transparent;
                             -fx-border-width: 0 0 1 0; -fx-padding: 18 24 18 24;">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Supplier Reliability"
                               style="-fx-font-size: 15px; -fx-font-weight: 700; -fx-text-fill: #111827;" />
                        <Label text="On-time delivery performance per supplier"
                               style="-fx-font-size: 12px; -fx-text-fill: #9CA3AF;" />
                    </VBox>
                    <Label fx:id="lblSupplierCount" text="0 suppliers"
                           style="-fx-font-size: 12px; -fx-text-fill: #6B7280;
                                  -fx-background-color: #F3F4F6; -fx-background-radius: 999;
                                  -fx-padding: 3 10 3 10;" />
                </HBox>

                <!-- Table -->
                <!--
                  columnResizePolicy MUST be set in the controller:
                  tableSuppliers.setColumnResizePolicy(TableView.CONSTRAINED_RESIZE_POLICY_ALL_COLUMNS)
                -->
                <TableView fx:id="tableSuppliers"
                           styleClass="reports-table"
                           style="-fx-background-color: transparent;
                                  -fx-table-cell-border-color: transparent;
                                  -fx-fixed-cell-size: 44;">
                    <columns>
                        <TableColumn fx:id="colSupplierName" text="Supplier"     minWidth="120" />
                        <TableColumn fx:id="colContact"      text="Contact"      minWidth="160" />
                        <TableColumn fx:id="colLeadDays"     text="Avg Lead (days)" minWidth="120" />
                        <TableColumn fx:id="colReliability"  text="On-time %"   minWidth="110" />
                        <TableColumn fx:id="colRating"       text="Rating"       minWidth="100" />
                    </columns>
                    <placeholder>
                        <VBox alignment="CENTER" spacing="8">
                            <Label text="No suppliers found"
                                   style="-fx-text-fill: #6B7280; -fx-font-size: 13px; -fx-font-weight: 600;" />
                            <Label text="Supplier data will appear here once available"
                                   style="-fx-text-fill: #9CA3AF; -fx-font-size: 12px;" />
                        </VBox>
                    </placeholder>
                </TableView>

                <!-- Table footer / total row -->
                <HBox alignment="CENTER_LEFT" spacing="0"
                      style="-fx-border-color: #E5E7EB transparent transparent transparent;
                             -fx-border-width: 1 0 0 0; -fx-padding: 12 24 12 24;
                             -fx-background-color: #FAFAFA;
                             -fx-background-radius: 0 0 10 10;">
                    <Label fx:id="lblAvgReliability" text="Average on-time rate: —"
                           style="-fx-font-size: 12px; -fx-text-fill: #6B7280;" />
                </HBox>
            </VBox>

            <!-- ══════════════════════════
                 LOW STOCK ALERT CARD
            ══════════════════════════ -->
            <VBox fx:id="lowStockCard"
                  style="-fx-background-color: white;
                         -fx-border-color: #E5E7EB; -fx-border-radius: 10;
                         -fx-background-radius: 10;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">

                <HBox alignment="CENTER_LEFT" spacing="0"
                      style="-fx-border-color: transparent transparent #E5E7EB transparent;
                             -fx-border-width: 0 0 1 0; -fx-padding: 18 24 18 24;">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Low Stock Alerts"
                               style="-fx-font-size: 15px; -fx-font-weight: 700; -fx-text-fill: #111827;" />
                        <Label text="Products at or below reorder threshold"
                               style="-fx-font-size: 12px; -fx-text-fill: #9CA3AF;" />
                    </VBox>
                    <Label fx:id="lblLowStockCount" text="0 items"
                           style="-fx-font-size: 12px; -fx-text-fill: white;
                                  -fx-background-color: #EF4444; -fx-background-radius: 999;
                                  -fx-padding: 3 10 3 10;" />
                </HBox>

                <TableView fx:id="tableLowStock"
                           styleClass="reports-table"
                           style="-fx-background-color: transparent;
                                  -fx-table-cell-border-color: transparent;
                                  -fx-fixed-cell-size: 44;">
                    <columns>
                        <TableColumn fx:id="colLowStockProduct"  text="Product"         minWidth="160" />
                        <TableColumn fx:id="colLowStockCategory" text="Category"        minWidth="120" />
                        <TableColumn fx:id="colCurrentStock"     text="Current Stock"   minWidth="120" />
                        <TableColumn fx:id="colReorderLevel"     text="Reorder Level"   minWidth="120" />
                        <TableColumn fx:id="colStockStatus"      text="Status"          minWidth="100" />
                    </columns>
                    <placeholder>
                        <VBox alignment="CENTER" spacing="6">
                            <Label text="✅  All products are well stocked"
                                   style="-fx-text-fill: #16A34A; -fx-font-size: 13px; -fx-font-weight: 600;" />
                        </VBox>
                    </placeholder>
                </TableView>

                <HBox alignment="CENTER_LEFT"
                      style="-fx-border-color: #E5E7EB transparent transparent transparent;
                             -fx-border-width: 1 0 0 0; -fx-padding: 12 24 12 24;
                             -fx-background-color: #FAFAFA; -fx-background-radius: 0 0 10 10;">
                    <Label text="Items shown are below their minimum reorder level."
                           style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF;" />
                </HBox>
            </VBox>

        </VBox>
    </content>
</ScrollPane>
