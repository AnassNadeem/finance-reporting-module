<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.text.Font?>

<!--
  RoleSelection — two clickable role cards with animated floating background.
  All card selection, scale animation and background animation are in the controller.
-->
<StackPane
    fx:id="rootPane"
    style="-fx-background-color: #F9FAFB;"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.raez.finance.controller.RoleSelectionController">

    <!-- ── Animated background layer (circles added + animated in controller) ── -->
    <Pane fx:id="animatedBg" style="-fx-background-color: transparent;" />

    <!-- ── Main card (fades in on load via controller) ── -->
    <VBox
        fx:id="mainCard"
        alignment="CENTER"
        maxWidth="560"
        spacing="0"
        opacity="0"
        style="-fx-background-color: white;
               -fx-background-radius: 16;
               -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 24, 0, 0, 4);">
        <padding><Insets top="48" right="48" bottom="48" left="48" /></padding>

        <!-- Header -->
        <VBox alignment="CENTER" spacing="6">
            <VBox.margin><Insets bottom="36" /></VBox.margin>

            <!-- Logo mark -->
            <StackPane
                prefWidth="56" prefHeight="56" maxWidth="56" maxHeight="56"
                style="-fx-background-color: #1E2939; -fx-background-radius: 12;">
                <VBox.margin><Insets bottom="20" /></VBox.margin>
                <SVGPath
                    content="M12 2L3 7v6c0 5.25 3.75 10.15 9 11.25C17.25 23.15 21 18.25 21 13V7l-9-5z"
                    fill="WHITE"
                    scaleX="1.0" scaleY="1.0" />
            </StackPane>

            <Label text="RAEZ Finance Portal"
                   style="-fx-font-size: 24px; -fx-font-weight: 700; -fx-text-fill: #111827;" />
            <Label text="Select your role to continue"
                   style="-fx-font-size: 14px; -fx-text-fill: #6B7280;" />
        </VBox>

        <!-- Role cards row -->
        <HBox spacing="20" alignment="CENTER">

            <!-- ── ADMIN CARD ── -->
            <VBox
                fx:id="adminCard"
                alignment="CENTER"
                spacing="12"
                prefWidth="200" minHeight="200"
                style="-fx-background-color: #1E2939;
                       -fx-background-radius: 12;
                       -fx-cursor: hand;"
                onMouseClicked="#handleAdminCardClick"
                onMouseEntered="#handleAdminCardHover"
                onMouseExited="#handleAdminCardExit">
                <padding><Insets top="28" right="24" bottom="28" left="24" /></padding>

                <!-- Shield icon wrapper -->
                <StackPane
                    prefWidth="52" prefHeight="52"
                    style="-fx-background-color: rgba(255,255,255,0.15); -fx-background-radius: 999;">
                    <VBox.margin><Insets bottom="4" /></VBox.margin>
                    <SVGPath
                        content="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z M9 12l2 2 4-4"
                        fill="TRANSPARENT"
                        stroke="WHITE"
                        strokeLineCap="ROUND"
                        strokeLineJoin="ROUND"
                        strokeWidth="2" />
                </StackPane>

                <Label text="Administrator"
                       style="-fx-font-size: 15px; -fx-font-weight: 700; -fx-text-fill: white;" />
                <Label text="Full system access"
                       style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.65);"
                       wrapText="true" />
            </VBox>

            <!-- ── FINANCE USER CARD ── -->
            <VBox
                fx:id="userCard"
                alignment="CENTER"
                spacing="12"
                prefWidth="200" minHeight="200"
                style="-fx-background-color: #F3F4F6;
                       -fx-background-radius: 12;
                       -fx-cursor: hand;"
                onMouseClicked="#handleUserCardClick"
                onMouseEntered="#handleUserCardHover"
                onMouseExited="#handleUserCardExit">
                <padding><Insets top="28" right="24" bottom="28" left="24" /></padding>

                <!-- Person icon wrapper -->
                <StackPane
                    prefWidth="52" prefHeight="52"
                    style="-fx-background-color: rgba(30,41,57,0.10); -fx-background-radius: 999;">
                    <VBox.margin><Insets bottom="4" /></VBox.margin>
                    <SVGPath
                        content="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2 M12 3a4 4 0 1 0 0 8 4 4 0 0 0 0-8z"
                        fill="TRANSPARENT"
                        stroke="#1E2939"
                        strokeLineCap="ROUND"
                        strokeLineJoin="ROUND"
                        strokeWidth="2" />
                </StackPane>

                <Label text="Finance User"
                       style="-fx-font-size: 15px; -fx-font-weight: 700; -fx-text-fill: #111827;" />
                <Label text="Reports &amp; analytics"
                       style="-fx-font-size: 12px; -fx-text-fill: #6B7280;"
                       wrapText="true" />
            </VBox>

        </HBox>

        <!-- Footer note -->
        <Label
            text="All access attempts are logged and monitored."
            style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF;"
            alignment="CENTER">
            <VBox.margin><Insets top="32" /></VBox.margin>
        </Label>

    </VBox>

</StackPane>
